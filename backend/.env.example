# Backend Environment Variables  
# Copy this file to .env and fill in the actual values

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/leave_management_system?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000

# CORS Configuration - Frontend URL that is allowed to make requests to this API
# For local development: http://localhost:5173 (or http://localhost:3000)
# For production on Vercel: https://your-vercel-domain.vercel.app
CLIENT_URL=https://your-vercel-domain.vercel.app

# Email Configuration (if using forgot password feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
